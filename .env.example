# Required
ANTHROPIC_API_KEY=sk-ant-...

# Custom API base URL (for third-party providers)
# Example for SiliconFlow: https://api.siliconflow.cn/v1
# Leave empty to use default Anthropic API
ANTHROPIC_BASE_URL=

# API format: "anthropic" or "openai"
# Use "openai" for SiliconFlow, DeepSeek, OpenRouter, etc.
API_FORMAT=openai

# Optional - strongly recommended for higher rate limits
NVD_API_KEY=
GITHUB_TOKEN=

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/ti.db

# Encryption key for API key storage (auto-generated on first start if empty)
SECRETS_ENCRYPTION_KEY=

# Model and cost
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
MONTHLY_BUDGET_USD=50
SINGLE_TASK_TOKEN_LIMIT=200000

# Agent config
RESEARCHER_COUNT_DEFAULT=4
RESEARCHER_MAX_ROUNDS=3
ENRICHMENT_TIMEOUT_S=15
SYNTHESIS_TIMEOUT_S=120
ANALYSIS_TIMEOUT_S=480

# Data directories
DATA_DIR=./data
ATTCK_BUNDLE_PATH=./data/attck/enterprise-attack.json

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Server
HOST=127.0.0.1
PORT=8000
